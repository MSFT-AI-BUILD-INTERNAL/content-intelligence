# Azure AI Foundry — Content Understanding (resource-level endpoint)
CONTENT_UNDERSTANDING_ENDPOINT=https://jinsungpark-westus-resource.services.ai.azure.com

# Azure AI Foundry resource endpoint (v1 API)
AZURE_OPENAI_ENDPOINT=https://jinsang-foundry.services.ai.azure.com

# LLM deployment name (for structured output refinement)
LLM_DEPLOYMENT=gpt-5.2-chat

# Document Intelligence Endpoint (same resource or separate)
DOCUMENT_INTELLIGENCE_ENDPOINT=https://jinsungpark-westus-resource.cognitiveservices.azure.com/

# NOTE: No API keys needed — authentication is handled via Azure Managed Identity.
# Ensure the identity has "Cognitive Services User" role assigned on the resource.
